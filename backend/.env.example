 # ═══════════════════════════════════════════════════════════════════════════════
#  VinmecPrep AI — .env.example
#  Copy thành .env và điền giá trị thật
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_MODEL=groq/qwen/qwen3-32b
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx         # console.groq.com
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Search ────────────────────────────────────────────────────────────────────
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # serper.dev
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET_KEY=replace_with_64_random_chars
WEB_SEARCH_TOP_K=5

# ── Weaviate ──────────────────────────────────────────────────────────────────
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_GRPC_HOST=weaviate
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=strong_password_here
REDIS_URL=redis://:strong_password_here@redis:6379/0
REDIS_SESSION_TTL=3600
REDIS_CACHE_TTL=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=20
MAX_INPUT_CHARS=2000

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourapp.example.com

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Legacy ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
